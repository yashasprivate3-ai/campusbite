NODE_ENV=development
CAMPUSBITE_API_HOST=127.0.0.1
CAMPUSBITE_API_PORT=3001
CAMPUSBITE_DB_PATH=./data/campusbite.db

# Server-side session settings. Secure cookies are forced when NODE_ENV=production.
CAMPUSBITE_AUTH_COOKIE_NAME=campusbite_session
CAMPUSBITE_AUTH_COOKIE_SECURE=false
CAMPUSBITE_AUTH_SESSION_TTL_HOURS=12
CAMPUSBITE_AUTH_SESSION_TOUCH_MINUTES=15
CAMPUSBITE_AUTH_LOGIN_MAX_ATTEMPTS=5
CAMPUSBITE_AUTH_LOGIN_WINDOW_MINUTES=10

# Google Identity Services. Use the same Google Web client ID for the backend
# and Vite frontend. Local authorized JavaScript origin: http://localhost:5173
# No Google client secret is used by this authentication-only flow.
CAMPUSBITE_GOOGLE_LOGIN_ENABLED=false
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
VITE_CAMPUSBITE_GOOGLE_LOGIN_ENABLED=false

# Sprint 7.2 phone verification. The development provider is local-only and
# must never be enabled with NODE_ENV=production. Keep real values in .env.
CAMPUSBITE_OTP_PROVIDER=development
CAMPUSBITE_DEV_OTP_CODE=
CAMPUSBITE_OTP_HASH_SECRET=

# Meta WhatsApp configuration contract only. Sprint 7.2 does not make Meta
# network requests; these values remain unused until a later provider sprint.
CAMPUSBITE_META_WHATSAPP_ACCESS_TOKEN=
CAMPUSBITE_META_WHATSAPP_PHONE_NUMBER_ID=
CAMPUSBITE_META_WHATSAPP_TEMPLATE_NAME=campusbite_phone_verification

# Development-only account seeding. Set true only in a local environment after
# supplying unique passwords of 12-128 characters. Never commit the real values.
CAMPUSBITE_DEV_ACCOUNTS_ENABLED=false
CAMPUSBITE_DEV_RESET_PASSWORDS=false
VITE_CAMPUSBITE_DEV_STUDENT_LOGIN_ENABLED=false

CAMPUSBITE_DEV_OWNER_NAME=CampusBite Owner
CAMPUSBITE_DEV_OWNER_LOGIN=
CAMPUSBITE_DEV_OWNER_PASSWORD=

CAMPUSBITE_DEV_KITCHEN_NAME=CampusBite Kitchen
CAMPUSBITE_DEV_KITCHEN_LOGIN=
CAMPUSBITE_DEV_KITCHEN_PASSWORD=

CAMPUSBITE_DEV_STUDENT_NAME=Development Student
CAMPUSBITE_DEV_STUDENT_LOGIN=
CAMPUSBITE_DEV_STUDENT_PASSWORD=
